#ktlint config file
#settings in https://pinterest.github.io/ktlint/latest/rules/standard/#__tabbed_77_1
[**/PreviewExample.kt]
ktlint_standard_parameter-list-wrapping = disabled

[**/Colors.kt]
ktlint_standard_no-blank-line-in-list = disabled

[*.{kt,kts}]
# Enable both dependent rules
ktlint_standard = enabled

ktlint_standard_trailing-comma-on-declaration-site = disabled
ktlint_standard_package-name = disabled
ktlint_standard_function-naming = disabled
ktlint_standard_comment-spacing = disabled
ktlint_standard_final-newline = disabled
ktlint_standard_no-empty-first-line-in-class-body = disabled
ktlint_standard_trailing-comma-on-call-site = disabled
ktlint_standard_function-signature = disabled
ktlint_standard_string-template-indent = disabled #by chain of indent-rule
ktlint_standard_indent = disabled #need custom rule with avoid @Annotations
ktlint_standard_multiline-expression-wrapping = disabled
#immune for no-wildcard in detekt config (detekt-setting/detekt.yml)
